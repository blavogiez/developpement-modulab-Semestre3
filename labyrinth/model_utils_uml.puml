@startuml
skinparam monochrome true
skinparam shadowing true
skinparam classAttributeIconSize 0

package model {
    class Maze {
        - observers: List<Observer<Maze>>
        - width: int
        - height: int
        - grid: boolean[][]
        - playerPosition: Position
        - entryPosition: Position
        - exitPosition: Position
        + Maze(width: int, height: int, wallPercentage: double, minPathLength: int)
        + Maze(width: int, height: int, wallPercentage: double)
        + add(observer: Observer<Maze>): boolean
        + movePlayer(direction: Direction)
        + isWall(x: int, y: int): boolean
        + isPlayerPositionAtExit(): boolean
    }

    class Position {
        - x: int
        - y: int
        + Position(x: int, y: int)
        + addX(x: int)
        + addY(y: int)
        + equals(o: Object): boolean
        + hashCode(): int
    }

    enum Direction {
        UP(0,-1)
        DOWN(0,1)
        LEFT(-1,0)
        RIGHT(1,0)
        {field} x: int
        {field} y: int
    }

    interface Observer<T> {
        + update(type: T)
    }

    abstract class GameMode {
        - currentMaze: Maze
        + createMaze(width: int, height: int, wallPercentage: double)
        + createMaze(width: int, height: int, wallPercentage: double, distanceBetweenEntryAndExit: int)
        + movePlayerPosition(direction: Direction)
        + isPlayerAtEnd(): boolean
    }

    class FreeMode {
        {static} + mazeWidth: int
        {static} + mazeHeight: int
        {static} + mazeWallPercentage: double
        + createMaze()
    }

    class ProgressionMode {
        - player: Player
        {static} + defaultProgress: PlayerProgress
        {static} + initDefaultProgress()
        + createMaze(chosenChallenge: Challenge)
    }

    class Player {
        - name: String
        - progress: PlayerProgress
        + Player(name: String)
        + calculateScore(): int
        + getHighestLevel(): int
    }

    class PlayerProgress {
        - levelProgress: Level[]
        + PlayerProgress(levelProgress: Level[])
        + copy(): PlayerProgress
        + markChallengeCompleted(challenge: Challenge, time: long)
        + getHighestLevel(): int
    }

    class Level {
        - number: int
        - challenges: Challenge[]
        + Level(number: int)
        + isCompleted(): boolean
    }

    class Challenge {
        - difficulty: String
        - width: int
        - height: int
        - wallPercentage: double
        - distanceBetweenEntryAndExit: int
        - timeCompleted: long
        - completed: boolean
        + Challenge(difficulty: String, width: int, height: int, wallPercentage: double, distanceBetweenEntryAndExit: int)
        + Challenge(difficulty: String, width: int, height: int, wallPercentage: double)
        + validate()
        + getScoreValue(): int
    }

    class PlayerDatabase {
        {static} - SAVE_FILE: String
        {static} + savePlayer(player: Player)
        {static} + loadPlayer(name: String): Player
        {static} + playerExists(name: String): boolean
        {static} + loadAllPlayers(): List<Player>
        {static} + clear()
    }

    package algorithm {
        abstract class MazeAlgorithmTemplate {
            # maze: boolean[][]
            # percentageWall: double
            # PATH: boolean
            # WALL: boolean
            # random: Random
            # markCell(x: int, y: int)
            # markCell(cellAlgorithmBoolean: CellAlgorithmBoolean)
            # markCell(position: Position)
            # markPathBetweenCell(x1: int, y1: int, x2: int, y2: int)
            # markPathBetweenCell(cellAlgorithmBoolean1: CellAlgorithmBoolean, cellAlgorithmBoolean2: CellAlgorithmBoolean)
            # markPathBetweenCell(pos1: Position, pos2: Position)
            # removePercentageWall()
            # isWall(x: int, y: int): boolean
            # isWall(cellAlgorithmBoolean: CellAlgorithmBoolean): boolean
            # isWall(position: Position): boolean
            {abstract} + getStart(): Position
            {abstract} + getEnd(): Position
            {abstract} + createMaze(width: int, height: int, percentageWall: double, pathLength: int): boolean[][]
        }

        abstract class MazeAlgorithmTemplateProfondeur {
            + createMaze(width: int, height: int, percentageWall: double, pathLength: int): boolean[][]
            {abstract} + createMaze(width: int, height: int, percentageWall: double): boolean[][]
        }

        class MazeAlgorithmPerfect {
            {static} - instance: MazeAlgorithmPerfect
            # tracePath()
            # findPath(cellAlgorithmBooleanStack: Stack<CellAlgorithmBoolean>): boolean
            {static} + getInstance(): MazeAlgorithmTemplate
            + createMaze(width: int, height: int, percentageOfWall: double): boolean[][]
            + getStart(): Position
            + getEnd(): Position
        }

        class MazeAlgorithmStandard {
            {static} - instance: MazeAlgorithmStandard
            # tracePath()
            # findPath(cellAlgorithmBooleanStack: Stack<CellAlgorithmBoolean>, visitedCellAlgorithmBoolean: Set<CellAlgorithmBoolean>): boolean
            # unmarkPathBetweenCell(x1: int, y1: int, x2: int, y2: int)
            # unmarkPathBetweenCell(c1: CellAlgorithmBoolean, c2: CellAlgorithmBoolean)
            {static} + getInstance(): MazeAlgorithmStandard
            + createMaze(width: int, height: int, percentageOfWall: double): boolean[][]
            + getStart(): Position
            + getEnd(): Position
        }

        class MazeAlgorithmStandardLargeur {
            {static} - instance: MazeAlgorithmStandardLargeur
            - start: Position
            - end: Position
            + createMaze(width: int, height: int, percentageOfWall: double, pathLength: int): boolean[][]
            + getStart(): Position
            + getEnd(): Position
            {static} + getInstance(): MazeAlgorithmStandardLargeur
        }

        enum MazeAlgorithmFactory {
            PERFECT
            PERFECTRANDOM
            STANDARD
            STANDARDRANDOM
            STANDARDLARGEUR
            - mazeAlgorithm: MazeAlgorithmTemplate
            + getAlgorithm(): MazeAlgorithmTemplate
        }

        class CellAlgorithmBoolean {
            {field} x: int
            {field} y: int
            + CellAlgorithmBoolean(x: int, y: int)
            + CellAlgorithmBoolean(position: Position)
            + add(x: int, y: int): CellAlgorithmBoolean
            + equals(obj: Object): boolean
            + hashCode(): int
        }

        class MazeSizeException {
            + MazeSizeException(message: String)
        }
    }

}

package utils {
    class ProgressionLoader {
        {static} - DEFAULT_PROGRESSION_FILE: String
        {static} + loadDefaultProgress(): PlayerProgress
    }
}

' Relationships - Model package
Maze --> "1" Position : playerPosition
Maze --> "1" Position : entryPosition
Maze --> "1" Position : exitPosition
Maze --> "*" Observer : observers
GameMode --> "1" Maze : currentMaze
GameMode <|-- FreeMode
GameMode <|-- ProgressionMode
ProgressionMode --> "1" Player : player
ProgressionMode --> "1" PlayerProgress : defaultProgress
Player --> "1" PlayerProgress : progress
PlayerProgress --> "*" Level : levelProgress
Level --> "*" Challenge : challenges

' Relationships - Algorithm package
MazeAlgorithmTemplate <|-- MazeAlgorithmTemplateProfondeur
MazeAlgorithmTemplateProfondeur <|-- MazeAlgorithmPerfect
MazeAlgorithmTemplateProfondeur <|-- MazeAlgorithmStandard
MazeAlgorithmTemplate <|-- MazeAlgorithmStandardLargeur
MazeAlgorithmFactory --> "1" MazeAlgorithmTemplate : mazeAlgorithm
Maze ..> MazeAlgorithmFactory : uses

' Relationships - Utils package
ProgressionLoader ..> PlayerProgress : creates
ProgressionLoader ..> Level : creates
ProgressionLoader ..> Challenge : creates

' Cross-package relationships
ProgressionMode ..> ProgressionLoader : uses

@enduml
