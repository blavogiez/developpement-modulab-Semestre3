<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="10.0" minWidth="10.0" prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.univlille.labyrinth.controller.freemode.FreeModeComponentConfigurationController">
   <top>
      <HBox alignment="CENTER" prefHeight="60.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Configuration des Composants">
               <font>
                  <Font size="30.0" />
               </font>
            </Label>
         </children>
      </HBox>
   </top>
   <center>
      <VBox spacing="15" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <children>
            <HBox spacing="20" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="10" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Entités">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <ListView fx:id="listView" prefHeight="250.0" VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10">
                           <children>
                              <ComboBox fx:id="comboBox1" prefWidth="120.0" />
                              <TextField fx:id="textField" prefWidth="60.0" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER">
                           <children>
                              <Button fx:id="buttonAdd" text="Ajouter" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <VBox spacing="10" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Pièges">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <ListView fx:id="trapListView" prefHeight="250.0" VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10">
                           <children>
                              <ComboBox fx:id="trapComboBox" prefWidth="150.0" />
                              <TextField fx:id="trapTextField" prefWidth="60.0" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER">
                           <children>
                              <Button fx:id="buttonAddTrap" text="Ajouter" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox spacing="10">
               <children>
                  <VBox alignment="CENTER" spacing="5">
                     <children>
                        <Label fx:id="errorLabel" style="-fx-text-fill: red;" text="Au moins 1 PLAYER et 1 EXIT requis" visible="false" />
                     </children>
                  </VBox>

                  <HBox alignment="CENTER" spacing="10">
                     <children>
                        <Button mnemonicParsing="false" onAction="#onValidate" prefWidth="100.0" text="Valider" />
                        <Button mnemonicParsing="false" onAction="#goToRetour" prefWidth="100.0" text="Retour" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
