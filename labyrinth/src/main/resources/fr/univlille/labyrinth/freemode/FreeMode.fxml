<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="473.0" prefWidth="572.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.univlille.labyrinth.controller.freemode.FreeModeController">
    <center>
        <VBox fx:id="menu" alignment="CENTER" spacing="10" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <HBox fx:id="line1" alignment="CENTER" spacing="10">
                    <children>
                        <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" text="Largeur :" />
                        <TextField fx:id="widthField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Label maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" text="Hauteur :" />
                        <TextField fx:id="heightField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Label fx:id="labelSlider" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" text="Pourcentage de murs :" />
                        <Slider fx:id="wallPercentageSlider" blockIncrement="0.05" majorTickUnit="0.2" max="1.0" maxHeight="-Infinity" maxWidth="-Infinity" min="0.0" minHeight="-Infinity" minWidth="-Infinity" showTickLabels="true" showTickMarks="true" value="0.0" />
                    </children>
                </HBox>
                <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="5">
                    <children>
                        <Label fx:id="errorLabel" style="-fx-text-fill: red;" text="Dimensions invalides : min 3x4 ou 4x3" visible="false" />
                    </children>
                </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity">
               <children>
                        <Button fx:id="bouttonValider" mnemonicParsing="false" onAction="#goToModeLaby" prefWidth="100" text="Valider" />
               </children>
            </VBox>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity">
               <children>
                        <Button fx:id="bouttonQuitter" mnemonicParsing="false" onAction="#goToAccueil" prefWidth="100" text="Retour" />
               </children>
            </VBox>
            </children>
        </VBox>
    </center>
    <top>
        <VBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="l" alignment="CENTER" text="Mode Libre">
                    <font>
                        <Font size="30.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" text="Création" textAlignment="CENTER">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </top>
</BorderPane>
