                  </Label>
                  <Button fx:id="bouttonLevel1Challenge1" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" scaleX="2.0" scaleY="2.0" text="1" VBox.vgrow="ALWAYS">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
