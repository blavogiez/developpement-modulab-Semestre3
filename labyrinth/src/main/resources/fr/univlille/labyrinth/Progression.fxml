            <VBox fx:id="etape3" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="etapes">
               <children>
                  <Label text="Étape 3" />
                  <Button fx:id="bouttonLevel3Challenge1" mnemonicParsing="false" scaleX="2.0" scaleY="2.0" text="1" VBox.vgrow="ALWAYS" />
