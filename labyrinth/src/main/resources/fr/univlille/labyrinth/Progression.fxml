      <HBox fx:id="menuEtape" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="etape1" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="etapes">
