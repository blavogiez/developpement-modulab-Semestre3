@startuml
skinparam monochrome true
skinparam shadowing true
skinparam classAttributeIconSize 0

class Main {
    {static} + main(args: String[])
    {static} + goTo(page: String)
    {static} + setDarkMode(darkMode: boolean)
    {static} + getTheme(): String
}

package controller {
    class AppState {
        {static} - instance: AppState
        - currentPlayer: Player
        - selectedLevelIndex: int
        - selectedChallengeIndex: int
        - selectedChallenge: Challenge
        {static} + getInstance(): AppState
        + reset()
    }

    class HomeMenuController {
        + initialize()
    }

    class GameModeSelectionController {
        + initialize()
    }

    class SettingsController {
        + initialize()
    }

    package freemode {
        class FreeModeController {
            + initialize()
        }

        class FreeModeLabyrinthController {
            - labyrinth: LabyrinthGridView
            - gameMode: FreeMode
            - chronoTimeline: Timeline
            + initialize()
            + movement(e: KeyEvent)
            + update(gameMode: GameMode)
        }
    }

    package progressionmode {
        abstract class AbstractProgressionModeLabyrinthController {
            # gameMode: ProgressionMode
            # chronoTimeline: Timeline
            + initialize()
            + movement(e: KeyEvent)
            + update(gameMode: GameMode)
            {abstract} # setupViews(gameMode: ProgressionMode): Node
            {abstract} # getViewSuffix(): String
        }

        class ProgressionModeLabyrinthController {
            - labyrinth: LabyrinthGridView
            # setupViews(gameMode: ProgressionMode): Node
            # getViewSuffix(): String
        }

        class LimitedViewProgressionModeLabyrinthController {
            - labyrinthFull: LimitedLabyrinthGridView
            - labyrinthLocal: LocalPlayerView
            # setupViews(gameMode: ProgressionMode): Node
            # getViewSuffix(): String
        }

        class PlayerNameEntryController {
            + initialize()
        }

        class ExistingProfileController {
            + initialize()
        }

        class LevelSelectionController {
            + initialize()
        }
    }
}

package model {
    package maze {
        class Maze {
            - width: int
            - height: int
            - grid: boolean[][]
            + add(observer: Observer<Maze>): boolean
            + movePlayer(direction: Direction)
            + isWall(x: int, y: int): boolean
            + isPlayerPositionAtExit(): boolean
        }

        class Position {
            - x: int
            - y: int
            + addX(x: int)
            + addY(y: int)
            + equals(o: Object): boolean
            + hashCode(): int
        }

        enum Direction {
            UP(0,-1)
            DOWN(0,1)
            LEFT(-1,0)
            RIGHT(1,0)
            {field} x: int
            {field} y: int
        }

        interface Observer<T> {
            + update(type: T)
        }
    }

    package gamemode {
        abstract class GameMode {
            - victoryObservers: List<Observer<GameMode>>
            + createMaze(width: int, height: int, wallPercentage: double)
            + createMaze(width: int, height: int, wallPercentage: double, distanceBetweenEntryAndExit: int)
            + movePlayerPosition(direction: Direction)
            + isPlayerAtEnd(): boolean
            + addVictoryObserver(observer: Observer<GameMode>)
            # notifyVictory()
            # handleVictory()
        }

        class FreeMode {
            {static} + mazeWidth: int
            {static} + mazeHeight: int
            {static} + mazeWallPercentage: double
            + createMaze()
        }

        class ProgressionMode {
            - player: Player
            - selectedChallenge: Challenge
            {static} + defaultProgress: PlayerProgress
            + createMaze(chosenChallenge: Challenge)
            # handleVictory()
        }
    }

    package save {
        class Player {
            - name: String
            + calculateScore(): int
            + getHighestLevel(): int
        }

        class PlayerProgress {
            + copy(): PlayerProgress
            + markChallengeCompleted(challenge: Challenge, time: long)
            + getHighestLevel(): int
        }

        class Level {
            - number: int
            + isCompleted(): boolean
        }

        class Challenge {
            - difficulty: String
            - width: int
            - height: int
            - wallPercentage: double
            - distanceBetweenEntryAndExit: int
            - timeCompleted: long
            - completed: boolean
            + validate()
            + getScoreValue(): int
        }

        class PlayerDatabase {
            {static} - SAVE_FILE: String
            {static} + savePlayer(player: Player)
            {static} + loadPlayer(name: String): Player
            {static} + playerExists(name: String): boolean
            {static} + loadAllPlayers(): List<Player>
            {static} + clear()
        }
    }
}

package view {
    class GameColors {
        {static} + PLAYER: String
        {static} + EXIT: String
        {static} + WALL: String
        {static} + PATH: String
        {static} + OUT_OF_BOUNDS: String
        {static} + COMPLETED: String
    }

    class LabyrinthGridView {
        # grid: GridPane
        + LabyrinthGridView(maze: Maze)
        + update(maze: Maze)
    }

    class LimitedLabyrinthGridView {
        # grid: GridPane
        + LimitedLabyrinthGridView(maze: Maze)
        + update(maze: Maze)
    }

    class LocalPlayerView {
        # grid: GridPane
        + LocalPlayerView(maze: Maze)
        + update(maze: Maze)
    }
}

Observer <|.. FreeModeLabyrinthController
Observer <|.. AbstractProgressionModeLabyrinthController
Observer <|.. LabyrinthGridView
Observer <|.. LimitedLabyrinthGridView
Observer <|.. LocalPlayerView

AbstractProgressionModeLabyrinthController <|-- ProgressionModeLabyrinthController
AbstractProgressionModeLabyrinthController <|-- LimitedViewProgressionModeLabyrinthController

GameMode <|-- FreeMode
GameMode <|-- ProgressionMode

Maze --> "1" Position : playerPosition
Maze --> "1" Position : entryPosition
Maze --> "1" Position : exitPosition
Maze --> "*" Observer : observers

GameMode --> "1" Maze : currentMaze

ProgressionMode --> "1" Player : player
ProgressionMode --> "1" PlayerProgress : defaultProgress

Player --> "1" PlayerProgress : progress
PlayerProgress --> "3" Level : levelProgress
Level --> "3" Challenge : challenges

AppState --> "1" Player : currentPlayer
AppState --> "1" Challenge : selectedChallenge

Main ..> HomeMenuController : navigates

FreeModeLabyrinthController ..> FreeMode : creates
FreeModeLabyrinthController ..> LabyrinthGridView : creates
AbstractProgressionModeLabyrinthController ..> ProgressionMode : creates
AbstractProgressionModeLabyrinthController ..> AppState : uses
ProgressionModeLabyrinthController ..> LabyrinthGridView : creates
LimitedViewProgressionModeLabyrinthController ..> LimitedLabyrinthGridView : creates
LimitedViewProgressionModeLabyrinthController ..> LocalPlayerView : creates

AbstractProgressionModeLabyrinthController ..> Observer
@enduml