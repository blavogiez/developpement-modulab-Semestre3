@startuml
skinparam monochrome true
skinparam shadowing true
skinparam classAttributeIconSize 0

package model.gamemode {
    abstract class GameMode {
        + GameMode(MazeManager, VictoryHandler, GameConfig)
        + movePlayerPosition(int, Direction)
        + addVictoryObserver(VictoryObserver<GameMode>)
        + getCurrentMaze() : ObservableMaze
        + setCurrentMaze(ObservableMaze)
        # notifyVictory()
        # notifyDefeat()
        # handleVictory(PlayerEntity)
        # handleLoose()
    }

    class FreeMode {
        + FreeMode(MazeManager, VictoryHandler, FreeModeConfig)
        + FreeMode(FreeModeConfig)
        + FreeMode()
        + createMaze()
        # handleVictory(PlayerEntity)
        + toString() : String
    }

    class ProgressionMode {
        {static} + initDefaultProgress()
        + ProgressionMode(MazeManager, ProgressionModeVictoryHandler, Player, Challenge)
        + ProgressionMode(Player, Challenge)
        + createMaze()
        + toString() : String
    }

    class MazeManager {
        + createMaze(GameConfig)
        + hasMaze() : boolean
        + randomWallRemoval(double)
        + getCurrentMaze() : ObservableMaze
        + setCurrentMaze(ObservableMaze)
        {static} + areDimensionsCorrect(int, int) : boolean
    }
}

package model.algorithm {
    abstract class MazeAlgorithm {
        + generateMaze(Maze)
        + generateExitAndPlayer(Maze)
        # removeWall(Position, Direction)
        # removeWall(Position, Position)
        # removeWall(Position, Position, Direction)
        {static} + positionCorrecte(int, int, int, int) : boolean
        {static} + allAreTrue(boolean[][])
    }

    enum MazeAlgorithmFactory {
        PERFECT
        FUSION
        FUSION_LEGACY
        RANDOM
        - MazeAlgorithm
        + getAlgorithm() : MazeAlgorithm
        + isPerfect() : boolean
    }
}

package model.maze {
    class Maze {
        - width
        - height
        - entryPosition
        - exitPosition
        - distanceBetweenEntryAndExit
        - wallPercentage
        - murVerticaux
        - murHorizontaux
        + getWidth() : int
        + getHeight() : int
        + getWallPercentage() : double
        + getDistanceBetweenEntryAndExit() : int
        + setDistanceBetweenEntryAndExit(int)
        + getEntryPosition() : Position
        + getExitPosition() : Position
        + getMurHorizontaux() : boolean[][]
        + getMurVerticaux() : boolean[][]
        + setEntry(Position)
        + setExit(Position)
        + setMurHorizontaux(boolean[][])
        + setMurVerticaux(boolean[][])
        + Maze(int, int, double, int, MazeAlgorithm)
        + Maze(int, int, int, MazeAlgorithm)
        + Maze(int, int, double)
        + Maze(int, int)
        + trapEffect(int, Position)
    }

    class ObservableMaze {
        - entityManager
        - trapManager
        + ObservableMaze(int, int, int, String, MazeAlgorithm, String)
        + ObservableMaze(int, int, double, int, String, MazeAlgorithm, String)
        + movePlayer(int, Direction) : boolean
        + trapEffect(int, Position)
        + getTrapManager() : TrapManager
        + getEntityManager() : EntityManager
        + setPlayerPosition(int, Position)
        + getObservers() : List<Observer<ObservableMaze>>
    }

    class EntityManager {
        + addCptPlayerID()
        + addEntity(Entity)
        + removeEntity(Entity)
        + moveEntities(int, ObservableMaze, Direction)
        + checkMonsterOnPlayer()
        + checkPlayerOnExit() : PlayerEntity
        + isEntityOnCell(Position) : boolean
        + clear()
    }

    class TrapManager {
        - trap : Trap[][]
        + TrapManager(ObservableMaze, String)
        + getTraps() : Trap[][]
        + trapEffect(int, Position)
    }

    class Position {
        + Position(int, int)
        + copy() : Position
        + add(int, int) : Position
        + min(Position) : Position
        + diff(Position) : Direction
    }

    enum Direction {
        UP
        DOWN
        LEFT
        RIGHT
    }
}

    package model.maze.entities {
        abstract class Entity {
        - position
        - moveBehavior
        + move(ObservableMaze, Direction) : boolean
        }

    class PlayerEntity

    class MonsterEntity
    class ExitEntity

    enum EntityType {
        PLAYER
        MONSTER
        EXIT
    }
}

    package model.maze.traps {
        class TrapManager
        class TrapSetup

        enum TrapFactory {
        + compactedValueOf(String) : TrapFactory
        + generateTrap() : Trap
        }
    }

    package model.maze.traps.trap {
        abstract class Trap {
            + onUse(int, Position, Position, ObservableMaze)
            + name() : String
        }

    }

    package model.gamemode.victory {
        interface VictoryHandler {
        + handleVictory(PlayerEntity)
        + handleLoose()
    }

    class FreeModeVictoryHandler {
        + handleVictory(PlayerEntity)
        + handleLoose()
    }

    class ProgressionModeVictoryHandler {
        + ProgressionModeVictoryHandler(Player, Challenge, Timer)
        + handleVictory(PlayerEntity)
        + handleLoose()
    }
}

GameMode <|-- FreeMode
GameMode <|-- ProgressionMode
GameMode --> MazeManager
GameMode --> VictoryHandler
GameMode --> model.gamemode.config.GameConfig
MazeManager --> ObservableMaze

ObservableMaze --> EntityManager
ObservableMaze --> TrapManager
EntityManager --> Entity
Entity <|-- PlayerEntity
Entity <|-- MonsterEntity
Entity <|-- ExitEntity

TrapManager --> Trap
model.maze.traps.TrapFactory --> Trap

MazeAlgorithmFactory --> MazeAlgorithm
Maze *--> Position
GameMode ..> model.VictoryObserver
@enduml
