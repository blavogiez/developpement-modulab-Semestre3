@startuml
skinparam monochrome true
skinparam shadowing true
skinparam classAttributeIconSize 0

class Maze {
  - width: int
  - height: int
  - grid: boolean[][]
  - playerPosition: Position
  + Maze(width: int, height: int, wallPercentage: int)
  + movePlayer(direction: String)
}

class Player {
  - name: String
  - score: int
  + Player(name: String)
  + addScore(points: int)
  + getHighestStage(): int
}

class PlayerProgress {
  + markChallengeCompleted(challenge: Challenge)
}

class Position {
  - x: int
  - y: int
  + Position(x: int, y: int)
}

abstract class GameMode {
  + start()
  + createMaze(width: int, height: int, wallPercentage: int): Maze
}

class FreeMode {
  + start()
  + createMaze(width: int, height: int, wallPercentage: int): Maze
}

class ProgressionMode {
  + start()
  + createMaze(width: int, height: int, wallPercentage: int): Maze
  + loadProgress(progress: PlayerProgress)
}

class Stage {
  - number: int
  + Stage(number: int)
}

class Challenge {
  - difficulty: String
  - width: int
  - height: int
  - wallPercentage: int
  - completed : boolean
  + Challenge(difficulty: String)
  + validate()
}

class Main {
  startGame(player: Player): GameMode
  movePlayer(game: GameMode, direction: String)
  displayProgress(player: Player)
  savePlayer(player: Player)
  loadGame(player: Player)
  
  'displayProgress(player: Player)'
}

class PlayerDatabase {
  {static} + savePlayer(player: Player)
  {static} + loadPlayer(name: String): Player
  {static} + playerExists(name: String): boolean
}

Maze --> "playerPosition 1" Position

GameMode --> "player 1" Player
GameMode --> "currentMaze 1" Maze

GameMode <|-- FreeMode
GameMode <|-- ProgressionMode
Stage --> "challenges 3" Challenge

Player --> "progress 1" PlayerProgress
PlayerProgress --> "stageProgress 3" Stage 
@enduml
