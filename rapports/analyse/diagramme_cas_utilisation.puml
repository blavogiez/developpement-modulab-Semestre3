actor "Système" as sy

rectangle Labyrinthe #lightyellow {
  usecase "Jouer" as UC1
  usecase "Commencer une partie" as UC2
  usecase "Se déplacer\ndans le labyrinthe" as UC3
  usecase "Afficher progression" as UC4
  usecase "Sauvegarder progression" as UC5
  usecase "Charger profil" as UC6
  usecase "Lancer mode progression" as UC7
}

